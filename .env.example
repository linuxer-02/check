# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Table & bucket names (defaults match render.yaml — only change if you renamed them)
SUPABASE_STATE_TABLE=rsvp_app_state
SUPABASE_CALC_TABLE=rsvp_calculations
SUPABASE_CALC_BUCKET=calculation-pdfs
SUPABASE_PROJECT_DOC_BUCKET=project-documents
SUPABASE_COMMON_BUCKET=commonData
SUPABASE_PID_BUCKET=PID
SUPABASE_GAD_BUCKET=GAD
SUPABASE_TDS_BUCKET=technicalDataSheet

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Get from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192

# ── Server ────────────────────────────────────────────────────────────────────
# Render injects PORT automatically. Set locally only if you need a specific port.
# PORT=8001
